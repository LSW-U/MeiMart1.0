{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "ignoreDeprecations": "6.0",
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"]
    },
    "jsx": "react-jsx",
    "types": ["jest", "react"]
  },
  "include": ["src/**/*", "app/**/*", "__tests__/**/*"],
  "exclude": ["node_modules", "dist"]
}
