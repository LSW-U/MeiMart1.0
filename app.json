{
  "expo": {
    "name": "MeiMart",
    "slug": "mei-mart-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#961813"
    },
    "scheme": "meimart",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.meimart.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "MeiMart 需要访问相机以上传商品图片和扫描二维码。",
        "NSPhotoLibraryUsageDescription": "MeiMart 需要访问相册以上传头像和评价图片。",
        "NSLocationWhenInUseUsageDescription": "MeiMart 需要访问位置以推荐附近商品和地址自动填充。",
        "NSContactsUsageDescription": "MeiMart 可读取联系人以快速填充收货地址。",
        "ITSAppUsesNonExemptEncryption": false
      },
      "appStoreUrl": "https://apps.apple.com/app/meimart/id000000000"
    },
    "android": {
      "package": "com.meimart.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.INTERNET",
        "android.permission.ACCESS_NETWORK_STATE",
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.ACCESS_FINE_LOCATION"
      ],
      "playStoreUrl": "https://play.google.com/store/apps/details?id=com.meimart.app"
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "extra": {
      "APP_ENV": "development",
      "API_BASE_URL": "http://localhost:3000/api",
      "SENTRY_DSN": "",
      "eas": {
        "projectId": "your-eas-project-id"
      }
    },
    "plugins": [
      "expo-router",
      "expo-localization",
      "expo-image",
      "expo-secure-store",
      "expo-splash-screen",
      "expo-font",
      "expo-status-bar",
      [
        "expo-updates",
        {
          "username": "your-expo-username"
        }
      ],
      "@sentry/react-native"
    ],
    "updates": {
      "url": "https://u.expo.dev/your-eas-project-id"
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "owner": "your-expo-username",
    "privacy": "unlisted",
    "description": "MeiMart - Timor-Leste 本地电商应用",
    "githubUrl": "https://github.com/your-org/mei-mart-app",
    "primaryColor": "#961813"
  }
}
